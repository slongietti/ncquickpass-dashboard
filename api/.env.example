# Backend (BFF) configuration
PORT=3000

# CORS is OFF unless this is set. Leave it EMPTY for every normal setup — the SPA
# is served same-origin with the API (dev proxy, docker nginx, prod CloudFront),
# so no CORS is needed. Only set it (to an exact https origin) if a browser on a
# DIFFERENT origin must call the API. Never point it at localhost in production.
CORS_ORIGIN=

# Secret used to sign the HttpOnly session cookie. MUST be a long random string in prod.
COOKIE_SECRET=dev-only-change-me-to-a-long-random-string

# Set to "true" when served over HTTPS so the session cookie is marked Secure.
COOKIE_SECURE=false

# NC Quick Pass upstream API
NCQP_BASE_URL=https://secure.ncquickpass.com
NCQP_CLIENT_ID=AMSExternalngAuthApp

# Background reconcile cron. Local/compose runs it in-process (daily); on Lambda
# it's auto-disabled (the process is frozen between invokes) and EventBridge
# Scheduler invokes the function instead, routed to POST /api/internal/cron.
# That endpoint requires the request body's `secret` to equal CRON_SECRET (set in
# the schedule's input payload). Leave empty and the endpoint stays closed — only
# needed for the Lambda deployment.
CRON_SECRET=

# Postgres connection string (Prisma via the `pg` driver adapter).
#   Local dev  → a local Postgres (e.g. the docker-compose `db` service):
#     postgresql://ncquickpass:dev-only-insecure-password@localhost:5432/ncquickpass
#   Production → the Neon serverless-Postgres connection string (keep sslmode=require).
# Never commit a real connection string — set it in .env (gitignored) / the
# platform's secret store.
DATABASE_URL="postgresql://ncquickpass:dev-only-insecure-password@localhost:5432/ncquickpass"

# Credential encryption for the unattended scheduler. Two backends for the same
# job; set one. CREDENTIAL_KEY (KMS) takes precedence over CREDENTIAL_KEY_LOCAL.
# If neither is set, credential storage (and unattended scheduling) is disabled.
#
# CREDENTIAL_KEY — production (AWS): a KMS customer-managed key ARN. The app never
#   holds key material — it calls KMS, and decryption is governed by the key policy
#   (grant only the job's IAM role, no humans). AWS region/credentials come from the
#   environment / instance role.
# CREDENTIAL_KEY=arn:aws:kms:us-east-1:111122223333:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# CREDENTIAL_KEY_LOCAL — local/dev: a 32-byte hex key (64 chars) for AES-256-GCM.
#   Anyone who can read the environment can decrypt, so dev only. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_KEY_LOCAL=
