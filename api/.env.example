# Backend (BFF) configuration
PORT=3000

# Origin allowed to call the API (the Angular dev server)
CORS_ORIGIN=http://localhost:4200

# Secret used to sign the HttpOnly session cookie. MUST be a long random string in prod.
COOKIE_SECRET=dev-only-change-me-to-a-long-random-string

# Set to "true" when served over HTTPS so the session cookie is marked Secure.
COOKIE_SECURE=false

# NC Quick Pass upstream API
NCQP_BASE_URL=https://secure.ncquickpass.com
NCQP_CLIENT_ID=AMSExternalngAuthApp

# SQLite database file (Prisma). Relative paths resolve from the api/ dir in dev;
# the container overrides this to the mounted volume (file:/data/ncquickpass.db).
DATABASE_URL="file:./dev.db"

# Credential encryption for the unattended scheduler. Two backends for the same
# job; set one. CREDENTIAL_KEY (KMS) takes precedence over CREDENTIAL_KEY_LOCAL.
# If neither is set, credential storage (and unattended scheduling) is disabled.
#
# CREDENTIAL_KEY — production (AWS): a KMS customer-managed key ARN. The app never
#   holds key material — it calls KMS, and decryption is governed by the key policy
#   (grant only the job's IAM role, no humans). AWS region/credentials come from the
#   environment / instance role.
# CREDENTIAL_KEY=arn:aws:kms:us-east-1:111122223333:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# CREDENTIAL_KEY_LOCAL — local/dev: a 32-byte hex key (64 chars) for AES-256-GCM.
#   Anyone who can read the environment can decrypt, so dev only. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_KEY_LOCAL=
