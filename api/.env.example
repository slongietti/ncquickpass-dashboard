# ============================================================================
# Backend (BFF) configuration. Copy to `.env` (gitignored) and fill in.
# Only the REQUIRED section must be set; everything else has a safe default.
# ============================================================================

# --- REQUIRED ---------------------------------------------------------------

# Postgres connection string (Prisma via the `pg` driver adapter). The API does
# not start without a reachable database.
#   Local dev  → the docker-compose `db` service:
#     postgresql://ncquickpass:dev-only-insecure-password@localhost:5432/ncquickpass
#   Production → the Neon serverless-Postgres string (keep sslmode=require).
# Never commit a real connection string — keep it in .env / the secret store.
DATABASE_URL="postgresql://ncquickpass:dev-only-insecure-password@localhost:5432/ncquickpass"

# Secret used to sign the HttpOnly session cookie. No default — login breaks if
# unset. Use a long random string in production. Generate one with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
COOKIE_SECRET=dev-only-change-me-to-a-long-random-string

# --- OPTIONAL (the code already defaults to the values shown) ----------------

# HTTP port the API listens on.
PORT=3000

# NC Quick Pass upstream API. Fixed constants — the app defaults to exactly
# these, so only set them to override (e.g. a test environment).
NCQP_BASE_URL=https://secure.ncquickpass.com
NCQP_CLIENT_ID=AMSExternalngAuthApp

# CORS is OFF unless this is set. Leave EMPTY for every normal setup — the SPA is
# served same-origin (dev proxy, docker nginx, prod CloudFront). Only set it to an
# exact https origin if a browser on a DIFFERENT origin must call the API. Never
# point it at localhost in production.
CORS_ORIGIN=

# Set to "true" when served over HTTPS so the session cookie is marked Secure.
COOKIE_SECURE=false

# --- OPTIONAL: unattended weekly scheduling (feature-gated) ------------------
# Leave the two below unset and everything works EXCEPT scheduling declarations
# while logged out. Quick options, ad-hoc, and immediate activation are
# unaffected.

# Credential encryption for the unattended scheduler. Set ONE. If neither is set,
# credential storage (and unattended scheduling) is disabled.
#
# CREDENTIAL_KEY — production (AWS): a KMS customer-managed key ARN. The app never
#   holds key material; decryption is governed by the KMS key policy (grant only
#   the job's IAM role, no humans). AWS region/credentials come from the
#   environment / instance role.
# CREDENTIAL_KEY=arn:aws:kms:us-east-1:111122223333:key/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
#
# CREDENTIAL_KEY_LOCAL — local/dev: a 32-byte hex key (64 chars) for AES-256-GCM.
#   Dev only (anyone who can read the env can decrypt). Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CREDENTIAL_KEY_LOCAL=

# Background reconcile cron. Local/compose runs it in-process (daily); on Lambda
# it is auto-disabled (the process is frozen between invokes) and EventBridge
# Scheduler invokes POST /api/internal/cron instead. That endpoint requires the
# request body's `secret` to equal CRON_SECRET. Leave empty and it stays closed —
# only needed for the Lambda deployment.
CRON_SECRET=
