/// Maps a concrete scheduled occurrence (UTC window) to the NCQP declaration
/// created for it. The natural key gives idempotent materialization.
model HOVDeclaration {
  id                String   @id @default(cuid())
  accountId         String // TENANT KEY (denormalized for row-level filtering)
  scheduleId        String
  transponderNumber String
  windowStart       DateTime // concrete UTC window
  windowEnd         DateTime
  ncqpDeclarationId String? // returned by NcqpService.activateHov
  status            String // materialized | canceled | superseded
  createdAt         DateTime @default(now())

  @@unique([accountId, transponderNumber, windowStart, windowEnd])
  @@index([accountId, status])
  @@index([scheduleId])
}
