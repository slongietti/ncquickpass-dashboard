/// Encrypted NCQP credentials (AES-256-GCM) enabling the unattended cron to
/// re-authenticate on the tenant's behalf. Opt-in; deleted when scheduling is off.
model Credential {
  accountId  String   @id // TENANT KEY
  ciphertext String
  iv         String
  authTag    String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}
